{
    // MODULES CONFIG

    // Clock
    "clock":{
        "interval": 60,
        "format": "{:%e %b %Y %H:%M}",
        "tooltip": true,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>",
        "on-click": "hyprmsg exec \\$calendar"
    },

    // Battery
    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15,
        },
        "format-charging": "ůįāĄ {capacity}%",
        "format": "{icon} {capacity}%",
        "format-icons": ["ůĪÉć", "ůįĀļ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"],
        "tooltip": true
    },

    // Screen Brightness
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["ůįÉě", "ůįÉü", "ůįÉ†"],
        "on-scroll-up": "hyprctl exec \\$brightness_up",
        "on-scroll-down": "hyprctl exec \\$brightness_down"
    },

    // Volume
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%{format_source}",
        "format-muted": "ůįĖĀ {format_source}",
        "format-source": "",
        "format-source-muted": " ůįć≠",
        "format-icons": {
            "headphone": "ůįčč",
            "headset": "ůįčé",
            "default": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"]
        },
        "tooltip-format": "{icon} ‚Ää{volume}% {format_source}",
        "on-click": "swaymsg exec \\$pulseaudio",
        "on-click-middle": "swaymsg exec \\$volume_mute",
        "on-scroll-up": "swaymsg exec \\$volume_up",
        "on-scroll-down": "swaymsg exec \\$volume_down"
    },

    // Networking
    "network": {
        "format": "{icon} {ifname}",
        "format-wifi": "{icon}",
        "format-ethernet": "ůįąÄ",
        "format-disconnected": "ůįĖ™",
        "format-disabled": "ůįÄĚ",
        "format-icons": [ "ůį§Į", "ůį§ü", "ůį§Ę", "ůį§•", "ůį§®" ],
        "tooltip-format": "{icon} {ifname}: {ipaddr} via {gwaddri}",
        "tooltip-format-ethernet": "{icon} {ifname}: {ipaddr}",
        "tooltip-format-wifi": "{icon} {ifname} ({essid}): {ipaddr}",
        "tooltip-format-disconnected": "{icon} disconnected",
        "tooltip-format-disabled": "{icon} disabled",
        "max-length": 50,
        "on-click": "alacritty -e nmtui"
    },
    
